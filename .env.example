# Application identity and runtime
APP_NAME=content-pipeline
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Required in production. Generate a unique value before deployment.
# APP_SECRET_KEY=replace-with-a-long-random-secret

# Optional OpenAI metadata-generation integration.
# OPENAI_API_KEY=replace-with-an-openai-api-key
# OPENAI_METADATA_MODEL=gpt-5-mini

# YouTube OAuth credential-file locations. Run `content-pipeline oauth-login`
# after setting the client secrets path to populate the token path.
# YOUTUBE_OAUTH_CLIENT_SECRETS_PATH=secrets/youtube-client.json
# YOUTUBE_OAUTH_TOKEN_PATH=secrets/youtube-token.json
